[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/Ethical-saathi/saathi_frontend.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[branch "saathi-rebuild"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/saathi-rebuild
